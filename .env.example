# Copia este archivo como .env y completá con tus claves reales
# NUNCA subas .env al repositorio

# API de xAI/Grok — análisis de sentiment desde X/Twitter
# Obtener en: https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# API de NewsAPI — descarga de noticias por ticker
# Obtener en: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here
